// ─────────────────────────────────────────────────────────────────────────────
// Butterworth ATR Volatility-Momentum Indicator
// ─────────────────────────────────────────────────────────────────────────────
// Institutional quant approach:
//   1. 2-pole Butterworth low-pass filter (causal, forward-only) on price
//   2. ATR expansion regime detection
//   3. ATR rate-of-change (volatility momentum)
//   4. Entries on filtered-price crossovers with vol confirmation
//
// CAUSAL FILTER: The Butterworth implementation below uses only past and
// current bars — zero lookahead bias. Matches scipy.signal.lfilter exactly.
// ─────────────────────────────────────────────────────────────────────────────
//@version=6
indicator("Butterworth ATR Vol-Momentum", shorttitle="BW-ATR", overlay=true,
     max_labels_count=500, max_lines_count=500)

// ══════════════════════════════════════
// INPUTS
// ══════════════════════════════════════
GRP_BW   = "Butterworth Filter"
GRP_VOL  = "Volatility / ATR"
GRP_RISK = "Risk Management"
GRP_VIS  = "Visuals"

bwFastPeriod = input.int(12,   "BW Fast Cutoff Period", minval=3, maxval=100, group=GRP_BW,
     tooltip="Lower = more responsive to price changes. This is the signal line.")
bwSlowPeriod = input.int(40,   "BW Slow Cutoff Period", minval=5, maxval=200, group=GRP_BW,
     tooltip="Higher = smoother trend line. Crossovers between fast/slow generate signals.")

atrLen       = input.int(14,   "ATR Length",             minval=3, maxval=50,  group=GRP_VOL)
volEmaLen    = input.int(20,   "Vol EMA Length",         minval=5, maxval=100, group=GRP_VOL,
     tooltip="EMA of ATR — baseline for 'normal' volatility.")
volExpansion = input.float(1.0, "Vol Expansion Threshold", minval=0.1, maxval=3.0, step=0.1, group=GRP_VOL,
     tooltip="ATR must exceed this × ATR_EMA to confirm entry. 1.0 = ATR above its own average.")
atrRocLen    = input.int(5,    "ATR ROC Length",         minval=1, maxval=20,  group=GRP_VOL,
     tooltip="Look-back for ATR rate-of-change. Positive ROC = volatility accelerating.")

slAtrMult    = input.float(2.0, "SL ATR Multiplier",    minval=0.5, maxval=5.0, step=0.1, group=GRP_RISK)
tpAtrMult    = input.float(3.5, "TP ATR Multiplier",    minval=0.5, maxval=10.0, step=0.1, group=GRP_RISK)

showBW       = input.bool(true,  "Show Butterworth Lines",  group=GRP_VIS)
showFill     = input.bool(true,  "Show Trend Fill",         group=GRP_VIS)
showSignals  = input.bool(true,  "Show Entry Signals",      group=GRP_VIS)
showSLTP     = input.bool(true,  "Show SL/TP Levels",       group=GRP_VIS)
showVolPanel = input.bool(true,  "Show Vol Expansion Panel", group=GRP_VIS)

bullColor    = input.color(#00E676, "Bull Color", group=GRP_VIS)
bearColor    = input.color(#FF5252, "Bear Color", group=GRP_VIS)

// ══════════════════════════════════════
// 2-POLE BUTTERWORTH LOW-PASS FILTER
// ══════════════════════════════════════
// Direct-form II transposed IIR filter, matching scipy.signal.butter + lfilter.
// Transfer function: H(z) = (b0 + b1*z^-1 + b2*z^-2) / (1 + a1*z^-1 + a2*z^-2)
//
// Coefficients derived from the bilinear transform of a 2nd-order analog
// Butterworth prototype with normalised cutoff wn = 2/period.
// ──────────────────────────────────────

butterworthFilter(float src, int period) =>
    // Normalised cutoff frequency
    float wn = 2.0 / math.max(period, 3)
    wn := math.min(math.max(wn, 0.0001), 0.9999)

    // Pre-warp for bilinear transform
    float warp = math.tan(math.pi * wn / 2.0)
    float warp2 = warp * warp
    float sqrt2 = math.sqrt(2.0)

    // Analog prototype → digital via bilinear transform
    float K = 1.0 + sqrt2 * warp + warp2

    // Numerator coefficients (b0, b1, b2)
    float b0 = warp2 / K
    float b1 = 2.0 * b0
    float b2 = b0

    // Denominator coefficients (a1, a2) — note: a0 = 1.0 after normalisation
    float a1 = 2.0 * (warp2 - 1.0) / K
    float a2 = (1.0 - sqrt2 * warp + warp2) / K

    // Direct-form II transposed — strictly causal
    var float y  = na
    var float d1 = 0.0
    var float d2 = 0.0

    if bar_index == 0
        y  := src
        d1 := 0.0
        d2 := 0.0
    else
        y  := b0 * src + d1
        d1 := b1 * src - a1 * y + d2
        d2 := b2 * src - a2 * y

    y

// ══════════════════════════════════════
// COMPUTE INDICATORS
// ══════════════════════════════════════

// Butterworth filtered price lines
float bwFast = butterworthFilter(close, bwFastPeriod)
float bwSlow = butterworthFilter(close, bwSlowPeriod)

// ATR and its EMA
float atrVal    = ta.atr(atrLen)
float atrEma    = ta.ema(atrVal, volEmaLen)

// ATR rate-of-change (volatility momentum)
float atrPrev   = nz(atrVal[atrRocLen], atrVal)
float atrRoc    = atrPrev > 0 ? (atrVal - atrPrev) / atrPrev : 0.0

// Volatility conditions
bool volExpanding = atrVal > volExpansion * atrEma
bool volMomentum  = atrRoc > 0

// Butterworth crossovers
bool bullCross = ta.crossover(bwFast, bwSlow)
bool bearCross = ta.crossunder(bwFast, bwSlow)

// Trend direction
bool trendBull = bwFast > bwSlow
bool trendBear = bwFast < bwSlow

// ══════════════════════════════════════
// SIGNAL LOGIC
// ══════════════════════════════════════

bool longSignal  = bullCross and volExpanding and volMomentum
bool shortSignal = bearCross and volExpanding and volMomentum

// SL/TP levels (displayed on signal bars)
float longSL  = longSignal  ? close - atrVal * slAtrMult : na
float longTP  = longSignal  ? close + atrVal * tpAtrMult : na
float shortSL = shortSignal ? close + atrVal * slAtrMult : na
float shortTP = shortSignal ? close - atrVal * tpAtrMult : na

// ══════════════════════════════════════
// PERSISTENT SL/TP LINES
// ══════════════════════════════════════
var float activeSL    = na
var float activeTP    = na
var float activeEntry = na
var int   activeDir   = 0  // 1 = long, -1 = short

if longSignal
    activeDir   := 1
    activeEntry := close
    activeSL    := close - atrVal * slAtrMult
    activeTP    := close + atrVal * tpAtrMult

if shortSignal
    activeDir   := -1
    activeEntry := close
    activeSL    := close + atrVal * slAtrMult
    activeTP    := close - atrVal * tpAtrMult

// Clear levels when hit
if activeDir == 1
    if high >= activeTP or low <= activeSL or bearCross
        activeDir   := 0
        activeSL    := na
        activeTP    := na
        activeEntry := na

if activeDir == -1
    if low <= activeTP or high >= activeSL or bullCross
        activeDir   := 0
        activeSL    := na
        activeTP    := na
        activeEntry := na

// ══════════════════════════════════════
// PLOTS — Butterworth Lines
// ══════════════════════════════════════
pFast = plot(showBW ? bwFast : na, "BW Fast", color=color.new(bullColor, 20), linewidth=2)
pSlow = plot(showBW ? bwSlow : na, "BW Slow", color=color.new(bearColor, 20), linewidth=2)

fill(pFast, pSlow,
     color=showFill ? (trendBull ? color.new(bullColor, 88) : color.new(bearColor, 88)) : na,
     title="Trend Fill")

// ══════════════════════════════════════
// PLOTS — SL/TP Levels
// ══════════════════════════════════════
plot(showSLTP and activeDir != 0 ? activeEntry : na, "Entry",
     color=color.new(#2979FF, 0), linewidth=2, style=plot.style_linebr)
plot(showSLTP and activeDir != 0 ? activeSL : na, "Stop Loss",
     color=color.new(#FF1744, 0), linewidth=2, style=plot.style_linebr)
plot(showSLTP and activeDir != 0 ? activeTP : na, "Take Profit",
     color=color.new(#00E676, 0), linewidth=2, style=plot.style_linebr)

// ══════════════════════════════════════
// PLOTS — Entry Signals
// ══════════════════════════════════════
plotshape(showSignals and longSignal,  title="Long",  location=location.belowbar,
     style=shape.labelup,   color=bullColor, textcolor=color.white, text="Long",  size=size.small)
plotshape(showSignals and shortSignal, title="Short", location=location.abovebar,
     style=shape.labeldown, color=bearColor, textcolor=color.white, text="Short", size=size.small)

// ══════════════════════════════════════
// VOLATILITY EXPANSION PANEL (bottom)
// ══════════════════════════════════════
// Background highlights when both vol conditions are met
bgcolor(showVolPanel and volExpanding and volMomentum ? color.new(#FFEB3B, 92) : na,
     title="Vol Expansion Active")

// ══════════════════════════════════════
// ALERTS
// ══════════════════════════════════════
alertcondition(longSignal,  title="BW-ATR Long",  message="Butterworth ATR: LONG signal — Vol expanding + momentum confirmed")
alertcondition(shortSignal, title="BW-ATR Short", message="Butterworth ATR: SHORT signal — Vol expanding + momentum confirmed")
alertcondition(volExpanding and volMomentum, title="Vol Regime Active", message="Butterworth ATR: Volatility expansion regime active")

// ══════════════════════════════════════
// INFO TABLE
// ══════════════════════════════════════
var table infoTable = table.new(position.top_right, 2, 9, color.new(#131722, 5), color.new(#2A2E39, 0), 1)

if barstate.islast
    trendStr = trendBull ? "Bullish" : trendBear ? "Bearish" : "Neutral"
    trendCol = trendBull ? bullColor : trendBear ? bearColor : color.gray

    table.cell(infoTable, 0, 0, "BW-ATR Vol-Mom",
         text_color=color.white, bgcolor=color.new(#2962FF, 0), text_size=size.small, text_halign=text.align_center)
    table.merge_cells(infoTable, 0, 0, 1, 0)

    table.cell(infoTable, 0, 1, "Trend",     text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 1, trendStr,    text_color=trendCol,   text_size=size.small)

    table.cell(infoTable, 0, 2, "BW Fast",   text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(bwFast, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 3, "BW Slow",   text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(bwSlow, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 4, "ATR",       text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 4, str.tostring(atrVal, "#.##"), text_color=color.white, text_size=size.small)

    volStr = volExpanding ? "EXPANDING" : "Normal"
    volCol = volExpanding ? bullColor : color.gray
    table.cell(infoTable, 0, 5, "Vol Regime", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 5, volStr,       text_color=volCol,     text_size=size.small)

    rocStr = str.tostring(atrRoc * 100, "#.#") + "%"
    rocCol = volMomentum ? bullColor : bearColor
    table.cell(infoTable, 0, 6, "ATR ROC",    text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 6, rocStr,        text_color=rocCol,     text_size=size.small)

    dirStr = activeDir == 1 ? "LONG" : activeDir == -1 ? "SHORT" : "Flat"
    dirCol = activeDir == 1 ? bullColor : activeDir == -1 ? bearColor : color.gray
    table.cell(infoTable, 0, 7, "Position",   text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 7, dirStr,        text_color=dirCol,     text_size=size.small)

    table.cell(infoTable, 0, 8, "Timeframe",  text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 8, timeframe.period, text_color=color.white, text_size=size.small)
